generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  authorId  Int?
  author      User?    @relation(fields: [authorId], references: [id])
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  name  String?
  posts  Post[]
}

model UploadFile {
  id          String    @id @default(cuid())
  fileName    String    // 原始文件名
  key         String    // 七牛云存储key
  url         String    // 完整访问外链
  mimeType    String?   // 文件类型
  size        Int?      // 文件大小 byte
  createdAt   DateTime  @default(now())
}

model Admin {
  id        Int    @id @default(autoincrement())
  username  String    @unique
  password  String    
  nickname  String?
  avatar    String?
  isSuper   Boolean  @default(false) // 超级管理员标记
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles Article[]
}

model Article {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(120)
  content     String
  cover       String?
  status      Int      @default(1) // 0草稿 1正常 2下架
  adminId     Int
  categoryId  Int?    // 可选分类
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin Admin @relation(fields: [adminId],references: [id],onDelete: Cascade)
  category ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  // 多对多标签
  tags ArticleTag[]


}


// 文章分类
model ArticleCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(60) // 分类名称唯一
  sort      Int      @default(0) // 排序权重
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]
}

// 文章标签
model ArticleTag {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(60) // 标签名唯一
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles Article[]
}

// 兰花品类枚举
enum OrchidsType {
  春兰
  春剑
  蕙兰
  莲瓣兰
  夏兰
  寒兰
  墨兰
  其他
}

model Zone {
  code          String        @id @db.VarChar(4)
  capacity      Int?          @default(132)
  currentCount  Int?          @default(0)
  createdAt     DateTime      @db.Timestamp(0) @default(now())
  updatedAt     DateTime      @db.Timestamp(0) @updatedAt
  inventories   Inventory[]

  @@map("zones")
}

model Orchid {
  id          Int             @id @default(autoincrement())
  name        String          @db.VarChar(100)
  type        OrchidsType
  createdAt   DateTime        @db.Timestamp(0) @default(now()) // 新增默认当前时间
  updatedAt   DateTime        @db.Timestamp(0) @updatedAt     // 自动更新时间
  inventories Inventory[]

  @@unique([name, type], map: "orchids_name_type")
  @@map("orchids")
}

model Inventory {
  id        Int           @id @default(autoincrement())
  zoneCode  String?      @db.VarChar(4) @map("zone_code")
  orchidId  Int?         @map("orchid_id")
  quantity  Int?         @default(0)
  createdAt DateTime     @db.Timestamp(0) @map("created_at") @default(now())
  updatedAt DateTime     @db.Timestamp(0) @map("updated_at") @updatedAt

  zone   Zone?   @relation(fields: [zoneCode], references: [code], onDelete: Cascade, map: "inventories_ibfk_31")
  orchid Orchid? @relation(fields: [orchidId], references: [id], onDelete: Cascade, map: "inventories_ibfk_32")

  @@unique([zoneCode, orchidId], map: "inventories_zone_code_orchid_id")
  @@index([orchidId], map: "orchid_id")
  @@map("inventories")
}